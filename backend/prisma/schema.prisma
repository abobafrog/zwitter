// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  bannerUrl    String?   @map("banner_url")
  birthDate    String?   @map("birth_date")
  id           String    @id @default(uuid())
  username     String    @unique @db.VarChar(50)
  email        String    @unique @db.VarChar(255)
  emailVerified Boolean  @default(false) @map("email_verified")
  emailVerifiedAt DateTime? @map("email_verified_at")
  passwordHash String    @map("password_hash")
  displayName  String    @map("display_name") @db.VarChar(100)
  bio          String?   @db.VarChar(160)
  avatarUrl    String?   @map("avatar_url")
  isVerified   Boolean   @default(false) @map("is_verified")
  isCommunity  Boolean   @default(false) @map("is_community")
  blockGroupInvites Boolean @default(false) @map("block_group_invites")
  messagePrivacy String   @default("everyone") @map("message_privacy") @db.VarChar(20)
  notifyLikes    Boolean  @default(true) @map("notify_likes")
  notifyReplies  Boolean  @default(true) @map("notify_replies")
  notifyRetweets Boolean  @default(true) @map("notify_retweets")
  notifyFollows  Boolean  @default(true) @map("notify_follows")
  notifyMessages Boolean  @default(true) @map("notify_messages")
  followersCount Int      @default(0) @map("followers_count")
  followingCount Int      @default(0) @map("following_count")
  tweetsCount    Int      @default(0) @map("tweets_count")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  // Relations
  tweets         Tweet[]
  tweetViews TweetView[]
  likes          Like[]
  retweets       Retweet[]
  bookmarks      Bookmark[]
  following      Follow[]  @relation("Following")
  followers      Follow[]  @relation("Followers")
  messages       Message[] @relation("SentMessages")
  receivedMsgs   Message[] @relation("ReceivedMessages")
  messageReactions MessageReaction[]
  chatParticipants ChatParticipant[]
  refreshTokens  RefreshToken[]
  accountTokens   AccountToken[]
  quickNotes      QuickNote[]
  serviceTasks    ServiceTask[]
  notifications  Notification[] @relation("NotificationUser")
  sentNotifications Notification[] @relation("NotificationFrom")
  ownedCommunities Community[] @relation("CommunityOwner")
  communityMemberships CommunityMember[]
  musicTrackLikes MusicTrackLike[]

  @@index([isCommunity, followersCount, createdAt])
  @@map("users")
}

model MusicTrack {
  id          String   @id @default(uuid())
  key         String   @unique @db.VarChar(240)
  title       String   @db.VarChar(240)
  artist      String   @db.VarChar(240)
  album       String?  @db.VarChar(240)
  imageUrl    String?  @map("image_url") @db.VarChar(1000)
  audioUrl    String?  @map("audio_url") @db.VarChar(1000)
  provider    String?  @db.VarChar(80)
  providerLabel String? @map("provider_label") @db.VarChar(120)
  duration    String?  @db.VarChar(20)
  durationSeconds Int? @map("duration_seconds")
  likesCount  Int      @default(0) @map("likes_count")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  likes MusicTrackLike[]

  @@index([likesCount, updatedAt])
  @@index([artist, title])
  @@map("music_tracks")
}

model MusicTrackLike {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  trackId   String   @map("track_id")
  createdAt DateTime @default(now()) @map("created_at")

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  track MusicTrack @relation(fields: [trackId], references: [id], onDelete: Cascade)

  @@unique([userId, trackId])
  @@index([userId, createdAt])
  @@index([trackId])
  @@map("music_track_likes")
}

model AccountToken {
  id        String   @id @default(uuid())
  tokenHash String   @unique @map("token_hash")
  userId    String   @map("user_id")
  type      String   @db.VarChar(40)
  payload   String?  @db.Text
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
  @@map("account_tokens")
}

model QuickNote {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  content   String   @db.VarChar(1000)
  color     String   @default("cyan") @db.VarChar(20)
  pinned    Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  history QuickNoteHistory[]

  @@index([userId, pinned, updatedAt])
  @@map("quick_notes")
}

model QuickNoteHistory {
  id        String   @id @default(uuid())
  noteId    String   @map("note_id")
  summary   String   @db.VarChar(180)
  createdAt DateTime @default(now()) @map("created_at")

  note QuickNote @relation(fields: [noteId], references: [id], onDelete: Cascade)

  @@index([noteId, createdAt])
  @@map("quick_note_history")
}

model ServiceTask {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  title     String   @db.VarChar(160)
  details   String?  @db.VarChar(1000)
  status    String   @default("todo") @db.VarChar(20)
  priority  String   @default("normal") @db.VarChar(20)
  dueDate   DateTime? @map("due_date")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status, dueDate])
  @@map("service_tasks")
}

model Community {
  id          String   @id @default(uuid())
  slug        String   @unique @db.VarChar(50)
  name        String   @db.VarChar(100)
  bio         String?  @db.VarChar(180)
  avatarUrl   String?  @map("avatar_url")
  bannerUrl   String?  @map("banner_url")
  ownerId     String   @map("owner_id")
  isVerified  Boolean  @default(false) @map("is_verified")
  membersCount Int     @default(0) @map("members_count")
  tweetsCount  Int     @default(0) @map("tweets_count")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  owner   User @relation("CommunityOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members CommunityMember[]
  tweets  Tweet[]

  @@index([membersCount, createdAt])
  @@map("communities")
}

model CommunityMember {
  id          String   @id @default(uuid())
  communityId String   @map("community_id")
  userId      String   @map("user_id")
  role        String   @default("member")
  createdAt   DateTime @default(now()) @map("created_at")

  community Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([communityId, userId])
  @@map("community_members")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model Tweet {
  viewsCount   Int   @default(0)   @map("views_count")
  likesCount   Int   @default(0)   @map("likes_count")
  retweetsCount Int  @default(0)   @map("retweets_count")
  repliesCount Int   @default(0)   @map("replies_count")
  bookmarksCount Int @default(0)   @map("bookmarks_count")
  id        String   @id @default(uuid())
  content   String   @db.VarChar(500)
  imageUrl  String?  @map("image_url")
  authorId  String   @map("author_id")
  communityId String? @map("community_id")
  views     TweetView[]
  parentId  String?  @map("parent_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  author   User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  community Community? @relation(fields: [communityId], references: [id], onDelete: Cascade)
  parent   Tweet?   @relation("TweetReplies", fields: [parentId], references: [id])
  replies  Tweet[]  @relation("TweetReplies")
  likes    Like[]
  retweets Retweet[]
  bookmarks Bookmark[]
  notifications Notification[]

  @@index([createdAt, id])
  @@index([authorId, createdAt])
  @@index([parentId, createdAt])
  @@index([communityId, createdAt])
  @@index([viewsCount, createdAt])
  @@index([viewsCount, createdAt, id])
  @@index([parentId, viewsCount, createdAt])
  @@map("tweets")
}

model TweetView {
  id        String   @id @default(cuid())
  tweetId   String   @map("tweet_id")
  userId    String?  @map("user_id")
  ipAddress String?  @map("ip_address")
  createdAt DateTime @default(now()) @map("created_at")

  tweet Tweet  @relation(fields: [tweetId], references: [id], onDelete: Cascade)
  user  User?  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tweetId, userId])
  @@index([tweetId])
  @@index([userId])
  @@index([createdAt])
  @@map("tweet_views")
}

model Like {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  tweetId   String   @map("tweet_id")
  createdAt DateTime @default(now()) @map("created_at")

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  tweet Tweet @relation(fields: [tweetId], references: [id], onDelete: Cascade)

  @@unique([userId, tweetId])
  @@index([tweetId])
  @@index([userId])
  @@map("likes")
}

model Retweet {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  tweetId   String   @map("tweet_id")
  createdAt DateTime @default(now()) @map("created_at")

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  tweet Tweet @relation(fields: [tweetId], references: [id], onDelete: Cascade)

  @@unique([userId, tweetId])
  @@index([userId, createdAt])
  @@index([tweetId])
  @@index([createdAt])
  @@map("retweets")
}

model Follow {
  id          String   @id @default(uuid())
  followerId  String   @map("follower_id")
  followingId String   @map("following_id")
  createdAt   DateTime @default(now()) @map("created_at")

  follower  User @relation("Following", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("Followers", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
  @@map("follows")
}

model Chat {
  id          String   @id @default(uuid())
  name        String?  @db.VarChar(100)
  description String?  @db.VarChar(180)
  avatarUrl   String?  @map("avatar_url")
  ownerId     String?  @map("owner_id")
  isGroup     Boolean  @default(false) @map("is_group")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  participants ChatParticipant[]
  messages     Message[]

  @@map("chats")
}

model ChatParticipant {
  id       String   @id @default(uuid())
  chatId   String   @map("chat_id")
  userId   String   @map("user_id")
  role     String   @default("member")
  joinedAt DateTime @default(now()) @map("joined_at")

  chat Chat @relation(fields: [chatId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([chatId, userId])
  @@index([userId])
  @@index([chatId])
  @@map("chat_participants")
}

model Message {
  id         String   @id @default(uuid())
  chatId     String   @map("chat_id")
  senderId   String   @map("sender_id")
  receiverId String?  @map("receiver_id")
  content    String   @db.VarChar(1000)
  imageUrl   String?  @map("image_url")
  isRead     Boolean  @default(false) @map("is_read")
  createdAt  DateTime @default(now()) @map("created_at")
  editedAt   DateTime? @map("edited_at")

  chat      Chat              @relation(fields: [chatId], references: [id], onDelete: Cascade)
  sender    User              @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiver  User?             @relation("ReceivedMessages", fields: [receiverId], references: [id])
  reactions MessageReaction[]

  @@index([chatId, createdAt])
  @@index([senderId])
  @@index([isRead])
  @@index([chatId, isRead, senderId])
  @@map("messages")
}

model MessageReaction {
  id        String   @id @default(uuid())
  messageId String   @map("message_id")
  userId    String   @map("user_id")
  emoji     String   @db.VarChar(16)
  createdAt DateTime @default(now()) @map("created_at")

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
  @@index([messageId])
  @@map("message_reactions")
}
model Bookmark {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  tweetId   String   @map("tweet_id")
  createdAt DateTime @default(now()) @map("created_at")

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  tweet Tweet @relation(fields: [tweetId], references: [id], onDelete: Cascade)

  @@unique([userId, tweetId])
  @@index([userId, createdAt])
  @@index([tweetId])
  @@index([createdAt])
  @@map("bookmarks")
}

model TopicStat {
  id        String   @id @default(uuid())
  name      String   @unique @db.VarChar(80)
  slug      String   @unique @db.VarChar(100)
  keywords  String[] @default([])
  posts     Int      @default(0)
  updatedAt DateTime @updatedAt @map("updated_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([posts, updatedAt])
  @@map("topic_stats")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  fromId    String   @map("from_id")
  type      String
  tweetId   String?  @map("tweet_id")
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  user  User   @relation("NotificationUser", fields: [userId], references: [id], onDelete: Cascade)
  from  User   @relation("NotificationFrom", fields: [fromId], references: [id], onDelete: Cascade)
  tweet Tweet? @relation(fields: [tweetId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
  @@map("notifications")
}
