# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/twitter_clone"
# Production example through PgBouncer:
# DATABASE_URL="postgresql://app_user:password@pgbouncer:6432/zwitter?pgbouncer=true&connection_limit=5&pool_timeout=20"
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production-min-32-chars"
JWT_REFRESH_SECRET="your-refresh-secret-key-change-in-production-min-32-chars"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Server
PORT=5000
NODE_ENV=development
FRONTEND_URL="http://localhost:3000"
CORS_ORIGINS="http://localhost:3000"

# Cloudinary (для загрузки файлов)
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=2000
TWEET_RATE_LIMIT_MAX=40
MESSAGE_RATE_LIMIT_MAX=90
UPLOAD_RATE_LIMIT_MAX=30
SOCKET_MAX_PAYLOAD_BYTES=131072
JOB_QUEUE_ENABLED=true
WORKER_CONCURRENCY=5
TREND_RECALCULATE_CRON="*/30 * * * *"
VACUUM_ANALYZE_CRON="0 3 * * 0"
SLOW_QUERY_MS=250
METRICS_AUTH_TOKEN=""
LOG_TO_STDOUT=true

# YooKassa
YOOKASSA_SHOP_ID=""
YOOKASSA_SECRET_KEY=""
YOOKASSA_PLUS_MONTH_AMOUNT="299.00"
YOOKASSA_PLUS_YEAR_AMOUNT="2990.00"
